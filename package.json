{
  "name": "clearline-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "ClearLine desktop app — Survey, Design, Go-Live for field techs",
  "author": "ClearLine",
  "main": "electron/main.js",
  "scripts": {
    "build:web": "npm --prefix frontend ci && npm --prefix frontend run build",
    "dev": "electron .",
    "start": "npm run build:web && electron .",
    "dist": "npm run build:web && electron-builder --mac --win",
    "dist:mac": "npm run build:web && electron-builder --mac",
    "dist:win": "npm run build:web && electron-builder --win"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.clearline.app",
    "productName": "ClearLine",
    "copyright": "Copyright © ClearLine",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "ClearLine-${version}-Windows-portable.exe"
    },
    "dmg": {
      "title": "ClearLine"
    }
  }
}
