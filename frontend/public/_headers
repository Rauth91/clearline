/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; connect-src 'self' wss: https:; img-src 'self' data: https:; object-src 'none'; frame-ancestors 'none'
  Permissions-Policy: microphone=(self), camera=(), geolocation=()
  Access-Control-Allow-Origin: https://clearline-8tw.pages.dev
